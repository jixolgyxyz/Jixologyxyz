SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
SMTP_ADMIN_EMAIL=test@example.com
SMTP_SENDER_NAME=Sender

RESEND_FROM_EMAIL=Sender <test@example.com>

# Email verification policy for Edge Functions
EMAIL_VERIFICATION_ENABLED=true
BOOTSTRAP_USER_SKIP_EMAIL_VERIFICATION=true