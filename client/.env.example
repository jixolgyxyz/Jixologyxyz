# Consigue estos valores en el dashboard de Supabase (Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

SUPABASE_SERVICE_ROLE_KEY=your-secret-key-here
VITE_SUPABASE_ANON_KEY=your-anon-key

# Debe coincidir con EMAIL_VERIFICATION_ENABLED en las Edge Functions.
VITE_EMAIL_VERIFICATION_ENABLED=true

# Gemini API (for weekly report generation)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Server Configuration
PORT=3000
JWT_SECRET=your-random-secret-string